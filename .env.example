# Oregon Legal Mind.ai Environment Configuration

# Application Settings
NODE_ENV=production
PORT=3000
DOMAIN=oregonlegalmind.ai

# LegalBot Voice AI System
TWILIO_ACCOUNT_SID=AC1234567890abcdef1234567890abcdef
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
LEGALBOT_PHONE_NUMBER=+15551234567
ELEVENLABS_API_KEY=sk-your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI Integration (for speech recognition)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Contact Information
SEAN_PHONE_NUMBER=+15419149150
FROM_EMAIL=contact@oregonlegalmind.ai

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Database URLs (Railway will auto-populate these)
DATABASE_URL=postgresql://user:password@host:5432/database
REDIS_URL=redis://user:password@host:6379

# Security
JWT_SECRET=your_super_secure_jwt_secret_here
SESSION_SECRET=your_super_secure_session_secret_here

# OpenClaw Integration (future)
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_WEBHOOK_SECRET=your_webhook_secret_here

# LegalBot System Prompt (customizable)
LEGALBOT_SYSTEM_PROMPT="You are LegalBot, Oregon Legal Mind's AI legal assistant and sales representative. You are professional, knowledgeable, and helpful. Your role is to qualify prospects, demonstrate our legal AI capabilities, and route leads appropriately."

# Feature Flags
ENABLE_VOICE_AI=true
ENABLE_LEAD_CAPTURE=true
ENABLE_DEMO_MODE=true
ENABLE_ANALYTICS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info